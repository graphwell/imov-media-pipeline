# ─── Banco ────────────────────────────────────────────────────
DATABASE_URL=postgresql://imov:password@localhost:5432/imov_media
DB_PASSWORD=password

# ─── Cache ───────────────────────────────────────────────────
REDIS_URL=redis://:password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_256_bits_minimum_change_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── IA Grok (xAI) ──────────────────────────────────────────
GROK_API_KEY=your_grok_api_key_here

# ─── Storage Cloudflare R2 ──────────────────────────────────
R2_ACCOUNT_ID=placeholder
R2_ACCESS_KEY_ID=placeholder
R2_SECRET_ACCESS_KEY=placeholder
R2_BUCKET=imov-media
R2_PUBLIC_URL=https://media.imov.somar.ia.br

# ─── Google Drive ────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY=placeholder
GOOGLE_OAUTH_CLIENT_ID=placeholder
GOOGLE_OAUTH_CLIENT_SECRET=placeholder

# ─── Dropbox ─────────────────────────────────────────────────
DROPBOX_APP_KEY=placeholder
DROPBOX_APP_SECRET=placeholder

# ─── URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_SITE_URL=https://imov.somar.ia.br
MEDIA_CDN_URL=https://media.imov.somar.ia.br
MAIN_SITE_URL=https://imov.somar.ia.br
MAIN_SITE_API_KEY=placeholder
CLOUDFLARE_ZONE_ID=placeholder
CLOUDFLARE_API_TOKEN=placeholder

# ─── Features ────────────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=5
MAX_CONCURRENT_PROCESSING=3
MAX_FILE_SIZE_MB=500
ENABLE_VIDEO_PROCESSING=true
ENABLE_AI_CLASSIFICATION=true
ENABLE_OCR=true
ENABLE_AUTO_PUBLISH=false
