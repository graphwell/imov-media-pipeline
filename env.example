# ═══════════════════════════════════════════════════════════════
# IMOV MEDIA PIPELINE AI — Variáveis de Ambiente
# Copiar para .env e preencher os valores
# ═══════════════════════════════════════════════════════════════

# ─── Banco de Dados PostgreSQL ────────────────────────────────
DATABASE_URL=postgresql://imov:CHANGE_ME@localhost:5432/imov_media
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── Autenticação JWT ─────────────────────────────────────────
# Gerar com: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_MINIMUM_32_CHARS
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Anthropic (Claude IA) ────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
# Modelo padrão — NÃO ALTERAR
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Cloudflare R2 Storage ───────────────────────────────────
# https://dash.cloudflare.com → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=imov-media
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# URL pública do bucket (configurar custom domain no R2)
R2_PUBLIC_URL=https://media.imov.somar.ia.br

# ─── Cloudflare Cache Purge ───────────────────────────────────
# Para purgar cache após publicação
CLOUDFLARE_ZONE_ID=your_zone_id
CLOUDFLARE_API_TOKEN=your_api_token

# ─── Google Drive ────────────────────────────────────────────
# Opção 1: Service Account (recomendado para pastas compartilhadas)
# Baixar JSON da Service Account no Google Cloud Console
# Codificar em base64: base64 -w 0 service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json

# Opção 2: OAuth2 (para pastas privadas do usuário)
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret

# ─── Dropbox (opcional) ──────────────────────────────────────
# https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret

# ─── OneDrive / Microsoft (opcional) ─────────────────────────
MICROSOFT_CLIENT_ID=your_azure_app_client_id
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret
MICROSOFT_TENANT_ID=common

# ─── URLs dos Serviços ───────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.imov.somar.ia.br
NEXT_PUBLIC_WS_URL=wss://api.imov.somar.ia.br
NEXT_PUBLIC_SITE_URL=https://imov.somar.ia.br
NEXT_PUBLIC_MEDIA_URL=https://media.imov.somar.ia.br

# ─── Site Principal (imov.somar.ia.br) ───────────────────────
# Webhook para notificar quando empreendimento é publicado
MAIN_SITE_URL=https://imov.somar.ia.br
MAIN_SITE_WEBHOOK_URL=https://imov.somar.ia.br/api/webhooks
MAIN_SITE_API_KEY=CHANGE_ME_SHARED_SECRET

# ─── Processamento ───────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=5
MAX_CONCURRENT_PROCESSING=3
MAX_FILE_SIZE_MB=500
TMP_DIR=/tmp/media-processing
CLEANUP_TMP_AFTER_HOURS=24

# ─── Features (ligar/desligar) ────────────────────────────────
ENABLE_VIDEO_PROCESSING=true
ENABLE_AI_CLASSIFICATION=true
ENABLE_OCR=true
ENABLE_AUTO_PUBLISH=false
ENABLE_SMART_CROP=true
ENABLE_HLS_STREAMING=true

# ─── Monitoramento ────────────────────────────────────────────
# Log level: error, warn, info, debug
LOG_LEVEL=info
ENABLE_METRICS=true
METRICS_PORT=9090

# ─── Email (opcional - notificações) ─────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@imov.somar.ia.br
SMTP_PASS=your_smtp_password
EMAIL_FROM=IMOV Media <noreply@imov.somar.ia.br>
